# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jansamaadhan.in
NEXT_PUBLIC_APP_NAME=JanSamaadhan

# ─── OTP / SMS provider (choose one) ───────────────────────────
# Option A: Msg91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_template_id
MSG91_SENDER_ID=JANSAM

# Option B: Twilio Verify
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option C: Fast2SMS (budget India option)
FAST2SMS_API_KEY=your_fast2sms_key

# ─── Session / JWT ──────────────────────────────────────────────
# Minimum 32 random chars — generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_32_plus_random_chars_here

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jansamaadhan

# ─── Redis (queue, sessions, rate-limiting) ─────────────────────
REDIS_URL=redis://localhost:6379

# ─── Payments ──────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Storage (documents) ───────────────────────────────────────
S3_BUCKET=jansamaadhan-docs
S3_REGION=ap-south-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
# OR Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=jansamaadhan-docs

# ─── Google OAuth (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── WhatsApp (for OTP + notifications) ────────────────────────
NEXT_PUBLIC_WA_NUMBER=918000000000
META_WA_TOKEN=your_whatsapp_business_api_token
META_WA_PHONE_ID=your_phone_number_id

# ─── Analytics (optional) ──────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
