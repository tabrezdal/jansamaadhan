# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jansamaadhan.in
NEXT_PUBLIC_APP_NAME=JanSamaadhan

# ─── Database (Vercel Postgres / Neon) ──────────────────────────
# Auto-populated by Vercel when you connect a Postgres database under
# Project → Storage. For local dev, run: vercel env pull .env.local
DATABASE_URL=postgres://user:password@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:password@host/db?sslmode=require

# ─── OTP / SMS — Msg91 (primary) ────────────────────────────────
MSG91_AUTH_KEY=your_msg91_api_token
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=JANSAM

# ─── Payments — Razorpay ────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── File Storage — Supabase Storage ────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key
SUPABASE_STORAGE_BUCKET=jansamaadhan-docs

# ─── Session ────────────────────────────────────────────────────
# Minimum 32 random chars — generate with: openssl rand -base64 32
# (Not currently used — session cookie is plain role:phone. Swap in
# Iron Session or a signed JWT before going to production.)
SESSION_SECRET=replace_with_32_plus_random_chars_here

# ─── WhatsApp ───────────────────────────────────────────────────
NEXT_PUBLIC_WA_NUMBER=918000000000

# ─── Analytics (optional) ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX


# ─── Resend (contact form) ───────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"
CONTACT_EMAIL="support@jansamaadhan.com"